{
  "name": "arena-god-eyes-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "src/main.cjs",
  "scripts": {
    "start": "electron .",
    "check": "node --check src/main.cjs && node --check src/preload.cjs",
    "publish:backend:mac": "node scripts/publish-backend.cjs osx-arm64",
    "publish:backend:win": "node scripts/publish-backend.cjs win-x64",
    "package:dir": "electron-builder --dir",
    "package:mac": "electron-builder --mac",
    "package:win": "electron-builder --win",
    "package:full:mac": "npm run publish:backend:mac && npm run package:mac",
    "package:full:win": "npm run publish:backend:win && npm run package:win"
  },
  "devDependencies": {
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12"
  },
  "build": {
    "appId": "com.arenagodeyes.desktop",
    "productName": "ArenaGodEyes",
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/backend",
        "to": "backend"
      }
    ],
    "directories": {
      "buildResources": "resources"
    },
    "mac": {
      "category": "public.app-category.games"
    },
    "win": {
      "target": "nsis"
    }
  }
}
